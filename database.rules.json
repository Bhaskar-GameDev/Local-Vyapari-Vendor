{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "roles": {
          "$role": {
            ".validate": "data.exists() && newData.val() === data.val()"
          }
        },
        "activeRole": {
          ".validate": "newData.isString() && (newData.val() === 'customer' || newData.val() === 'merchant') && root.child('users').child($uid).child('roles').child(newData.val()).val() === true"
        }
      }
    },
    "phones": {
      "$phone": {
        ".read": "true",
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid) && newData.val() === auth.uid"
      }
    },
    "otps": {
      "$phone": {
        ".read": "false",
        ".write": "false"
      }
    },
    "otp_rate_limit": {
      "$phone": {
        ".read": "false",
        ".write": "false"
      }
    },
    "products": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "offers": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "shop": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        "latitude": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "longitude": {
          ".validate": "!newData.exists() || newData.isNumber()"
        }
      }
    },
    "password_resets": {
      "$phone": {
        ".read": "true",
        ".write": "!data.exists() && newData.child('status').val() === 'pending'"
      }
    },
    "analytics": {
      "$vendorUid": {
        ".read": "auth != null && auth.uid === $vendorUid",
        ".write": "auth != null && auth.uid === $vendorUid"
      }
    },
    "chats": {
      "$firstId": {
        ".read": "auth != null && auth.uid === $firstId",
        ".write": "auth != null && auth.uid === $firstId",
        "$secondId": {
          "messages": {
            "$messageId": {
              ".write": "auth != null && (auth.uid === $firstId || auth.uid === $secondId)"
            }
          },
          "lastMessage": {
            ".write": "auth != null && (auth.uid === $firstId || auth.uid === $secondId)"
          }
        }
      }
    },
    "users_devices": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
