{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "roles": {
          "$role": {
            ".validate": "data.exists() && newData.val() === data.val()"
          }
        },
        "activeRole": {
          ".validate": "newData.isString() && (newData.val() === 'customer' || newData.val() === 'merchant') && root.child('users').child($uid).child('roles').child(newData.val()).val() === true"
        }
      }
    },
    "phones": {
      "$phone": {
        ".read": "true",
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid) && newData.val() === auth.uid"
      }
    },
    "otps": {
      "$phone": {
        ".read": "false",
        ".write": "false"
      }
    },
    "otp_rate_limit": {
      "$phone": {
        ".read": "false",
        ".write": "false"
      }
    },
    "products": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "offers": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "shop": {
      ".read": "true",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        "latitude": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "longitude": {
          ".validate": "!newData.exists() || newData.isNumber()"
        }
      }
    },
    "password_resets": {
      "$phone": {
        ".read": "true",
        ".write": "!data.exists() && newData.child('status').val() === 'pending'"
      }
    },
    "analytics": {
      "$vendorUid": {
        ".read": "auth != null && auth.uid === $vendorUid",
        ".write": "auth != null"
      }
    },
    "chats": {
      "$ownerId": {
        ".read": "auth != null && auth.uid === $ownerId",
        ".write": false,
        "$peerId": {
          ".read": "auth != null && (auth.uid === $ownerId || auth.uid === $peerId)",
          ".write": "auth != null && ((!newData.exists() && auth.uid === $ownerId) || ((auth.uid === $ownerId || auth.uid === $peerId) && ((newData.child('vendorId').val() === $ownerId && newData.child('customerId').val() === $peerId) || (newData.child('vendorId').val() === $peerId && newData.child('customerId').val() === $ownerId)) && newData.child('shopId').val() === newData.child('vendorId').val() && root.child('shop').child(newData.child('vendorId').val()).exists()))",
          "vendorId": {
            ".validate": "newData.isString() && (newData.val() === $ownerId || newData.val() === $peerId)"
          },
          "customerId": {
            ".validate": "newData.isString() && (newData.val() === $ownerId || newData.val() === $peerId)"
          },
          "shopId": {
            ".validate": "newData.isString() && (newData.val() === $ownerId || newData.val() === $peerId) && root.child('shop').child(newData.val()).exists()"
          },
          "messages": {
            "$messageId": {
              ".validate": "(data.exists() && newData.val() === data.val()) || (newData.hasChildren(['senderId', 'receiverId', 'vendorId', 'customerId', 'shopId', 'text', 'timestamp']) && (newData.child('senderId').val() === $ownerId || newData.child('senderId').val() === $peerId) && (newData.child('receiverId').val() === $ownerId || newData.child('receiverId').val() === $peerId) && newData.child('senderId').val() !== newData.child('receiverId').val() && ((newData.child('vendorId').val() === $ownerId && newData.child('customerId').val() === $peerId) || (newData.child('vendorId').val() === $peerId && newData.child('customerId').val() === $ownerId)) && newData.child('shopId').val() === newData.child('vendorId').val() && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('timestamp').isNumber())"
            }
          },
          "lastMessage": {
            "text": {
              ".validate": "newData.isString()"
            },
            "timestamp": {
              ".validate": "newData.isNumber()"
            },
            "senderId": {
              ".validate": "newData.isString() && (newData.val() === $ownerId || newData.val() === $peerId)"
            },
            "vendorId": {
              ".validate": "newData.isString() && (newData.val() === $ownerId || newData.val() === $peerId)"
            },
            "customerId": {
              ".validate": "newData.isString() && (newData.val() === $ownerId || newData.val() === $peerId)"
            },
            "shopId": {
              ".validate": "newData.isString() && (newData.val() === $ownerId || newData.val() === $peerId) && root.child('shop').child(newData.val()).exists()"
            },
            "unread": {
              ".write": "auth != null && auth.uid === $ownerId",
              ".validate": "newData.isBoolean()"
            }
          },
          "userName": {
            ".validate": "newData.isString()"
          },
          "shopName": {
            ".validate": "newData.isString()"
          },
          "shopLogo": {
            ".validate": "newData.isString()"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },
    "users_devices": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
