rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the authenticated user matches the shop ID
    function isShopOwner(shopId) {
      return isAuthenticated() && request.auth.uid == shopId;
    }

    // Helper to validate that the file is an image and under 5MB
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

    match /shops/{shopId}/{allPaths=**} {
      allow read: if true;
      allow write: if isShopOwner(shopId) && (request.resource == null || isValidImage());
    }

    match /products/{shopId}/{allPaths=**} {
      allow read: if true;
      allow write: if isShopOwner(shopId) && (request.resource == null || isValidImage());
    }
  }
}

