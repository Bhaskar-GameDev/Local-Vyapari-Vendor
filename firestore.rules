rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    function isVendor(shopId) {
      return isAuthenticated() && get(/databases/$(database)/documents/shops/$(shopId)).data.vendorId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isVendor(shopId);
    }

    match /products/{productId} {
      allow read: if resource.data.isActive == true || isVendor(resource.data.shopId);
      allow create: if isVendor(request.resource.data.shopId);
      allow update, delete: if isVendor(resource.data.shopId);
    }

    match /offers/{offerId} {
      allow read: if resource.data.status == 'active';
      allow write: if isVendor(request.resource.data.shopId);
    }

    match /analytics_summaries/{summaryId} {
      allow read: if isVendor(resource.data.shopId);
      allow write: if false; // Only Cloud Functions can write analytics
    }
  }
}
